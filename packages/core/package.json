{
  "name": "@vorq/core",
  "version": "0.1.0",
  "description": "Distributed task queue for TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": ["task-queue", "distributed", "workers", "typescript", "queue"],
  "license": "MIT",
  "peerDependencies": {
    "@prisma/client": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    }
  },
  "dependencies": {
    "cron-parser": "5.5.0"
  },
  "devDependencies": {
    "@prisma/client": "6.19.2",
    "prisma": "6.19.2"
  }
}

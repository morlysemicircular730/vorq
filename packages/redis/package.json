{
  "name": "@vorq/redis",
  "version": "0.1.0",
  "description": "Redis transport adapter for Vorq",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "dependencies": {
    "ioredis": "5.4.2"
  },
  "peerDependencies": {
    "@vorq/core": "^0.1.0"
  }
}
